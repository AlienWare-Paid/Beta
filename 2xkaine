-- MAIN LOOP & ROTATING CROSSHAIR
-- ==============================================
RunService.RenderStepped:Connect(function(Delta)
    -- 🎯 ROTATE CROSSHAIR ONLY WHEN GUI IS OPEN
    if MenuOpen then
        CrosshairRot += Delta * 180
        Crosshair.Rotation = CrosshairRot % 360
    end

    -- UPDATE FOV CIRCLE
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local TargetPos, BestDist, Center = nil, math.huge, Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local MaxFOV = _G.FOVEnabled and _G.FOVSize or math.huge
    CurrentTarget = nil

    -- HP CHECK
    local CanAim = false
    if LocalPlayer.Character then
        local MyHum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if MyHum and MyHum.Health >= _G.MinSelfHP then
            CanAim = true
        end
    end

    -- TARGET SCAN
    local function Check(Ply)
        if not Ply or not Ply.Character or not IsValidTarget(Ply.Character) then return end
        local TargetHum = Ply.Character:FindFirstChild("Humanoid")
        if not TargetHum or TargetHum.Health < _G.MinTargetHP then return end
        local AimPart = GetTargetPart(Ply.Character)
        local Pos, Vis = Camera:WorldToScreenPoint(AimPart.Position)
        local D = (Vector2.new(Pos.X,Pos.Y)-Center).Magnitude
        if Vis and D<MaxFOV and (not _G.WallCheckEnabled or CanSee(AimPart)) and D<BestDist then
            BestDist=D; CurrentTarget=Ply
            TargetPos = _G.PredictionEnabled and AimPart.Position + Ply.Character.HumanoidRootPart.Velocity*(_G.AimPrediction/100)*0.15 or AimPart.Position
        end
    end

    -- AIMLOCK
    if _G.AimlockEnabled and CanAim then
        if next(PriorityList) then for _,D in pairs(PriorityList) do Check(D.Player) end
        else for _,P in pairs(Players:GetPlayers()) do if P~=LocalPlayer then Check(P) end end end
        if TargetPos then Camera.CFrame = _G.AimSpeedEnabled and Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, TargetPos), _G.AimSpeed/500) or CFrame.new(Camera.CFrame.Position, TargetPos) end
    end

    -- AUTO AIR
    if _G.AutoAirEnabled and CurrentTarget and CurrentTarget.Character then
        local TargetHum = CurrentTarget.Character:FindFirstChild("Humanoid")
        if TargetHum then
            if not JumpData[CurrentTarget.UserId] then JumpData[CurrentTarget.UserId] = {OnGround = true, Shot = false} end
            local Data = JumpData[CurrentTarget.UserId]
            local IsInAir = TargetHum.FloorMaterial == Enum.Material.Air
            if Data.OnGround and IsInAir and not Data.Shot then
                if CanSee(GetTargetPart(CurrentTarget.Character)) then
                    local Tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if Tool then Tool:Activate() end
                end
                Data.Shot = true
            elseif not IsInAir then Data.Shot = false end
            Data.OnGround = not IsInAir
        end
    end

    -- PRIORITY ESP
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
    for Id,Data in pairs(PriorityList) do
        local P = Data.Player
        if P and P.Character and P.Character.PrimaryPart then
            local Pos, Vis = Camera:WorldToScreenPoint(P.Character.PrimaryPart.Position)
            local Show = _G.PriorityESPEnabled and Vis
            Data.Tracer.Visible = Show
            Data.NameTag.Visible = Show
            if Show then
                Data.Tracer.From = ScreenCenter
                Data.Tracer.To = Vector2.new(Pos.X, Pos.Y)
                Data.NameTag.Position = Vector2.new(Pos.X, Pos.Y - 22)
                Data.NameTag.Text = P.Name
            end
        end
    end

    -- STATUS HUD
    local HasValidTarget = CurrentTarget ~= nil and _G.StatusHudEnabled
    StatusHud.Visible = HasValidTarget
    PartCon.Visible = HasValidTarget

    if HasValidTarget and CurrentTarget.Character then
        local H = CurrentTarget.Character:FindFirstChild("Humanoid")
        HudName.Text=CurrentTarget.Name; HudPart.Text="Target: ".._G.TargetPart
        HudDist.Text="Distance: "..math.floor((GetTargetPart(CurrentTarget.Character).Position-Camera.CFrame.Position).Magnitude).." studs"
        pcall(function() Avatar.Image = "rbxthumb://type=AvatarHeadShot&id="..CurrentTarget.UserId.."&w=150&h=150" end)
        if H then HealthBar.Size=UDim2.new(math.max(0,H.Health)/math.max(1,H.MaxHealth),0,1,0); HudHealthTxt.Text=math.floor(H.Health).." / "..math.floor(H.MaxHealth) end
    end
end)
