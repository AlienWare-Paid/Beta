local function MakeToggle(Name, PosY, Key)
    local Con = Instance.new("Frame", Tabs[1])
    Con.Size = UDim2.new(1,-20,0,38)
    Con.Position = UDim2.new(0,10,0,PosY)
    Con.BackgroundTransparency = 0.92
    Con.BackgroundColor3 = C.DarkBG
    Con.MouseEnter:Connect(function() TweenService:Create(Con, Anim.Fast, {BackgroundTransparency = 0.85}):Play() end)
    Con.MouseLeave:Connect(function() TweenService:Create(Con, Anim.Fast, {BackgroundTransparency = 0.92}):Play() end)

    local Lab = Instance.new("TextLabel", Con)
    Lab.Size = UDim2.new(1,-65,1,0)
    Lab.Position = UDim2.new(0,12,0,0)
    Lab.BackgroundTransparency = 1
    Lab.Text = Name
    Lab.Font = Enum.Font.GothamMedium
    Lab.TextColor3 = Color3.new(0.9,0.9,0.9)
    Lab.TextSize = 17
    Lab.TextXAlignment = Enum.TextXAlignment.Left

    local Bg = Instance.new("Frame", Con)
    Bg.Size = UDim2.new(0,40,0,22)
    Bg.Position = UDim2.new(1,-52,0.5,-11)
    Bg.BackgroundColor3 = _G[Key] and C.MainGreen or C.ToggleOffBg
    Instance.new("UICorner", Bg).CornerRadius = UDim.new(1,0)

    local Knob = Instance.new("Frame", Bg)
    Knob.Size = UDim2.new(0,18,0,18)
    Knob.Position = _G[Key] and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)
    Knob.BackgroundColor3 = C.ToggleOffKnob
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1,0)

    if Key == "AimlockEnabled" then
        AimlockToggleBg = Bg
        AimlockToggleKnob = Knob
    end

    Bg.InputBegan:Connect(function(I)
        if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then
            _G[Key] = not _G[Key]
            PlaySound(Sounds.Click)
            TweenService:Create(Bg, Anim.Fast, {BackgroundColor3 = _G[Key] and C.MainGreen or C.ToggleOffBg}):Play()
            TweenService:Create(Knob, Anim.Fast, {Position = _G[Key] and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}):Play()
        end
    end)
end

local function MakeFOVSlider(Name, PosY, ToggleKey, ValKey, Min, Max, Def)
    local Con = Instance.new("Frame", Tabs[1])
    Con.Size = UDim2.new(1,-20,0,55)
    Con.Position = UDim2.new(0,10,0,PosY)
    Con.BackgroundTransparency = 0.92
    Con.BackgroundColor3 = C.DarkBG
    Con.MouseEnter:Connect(function() TweenService:Create(Con, Anim.Fast, {BackgroundTransparency = 0.85}):Play() end)
    Con.MouseLeave:Connect(function() TweenService:Create(Con, Anim.Fast, {BackgroundTransparency = 0.92}):Play() end)

    local Bg = Instance.new("Frame", Con)
    Bg.Size = UDim2.new(0,40,0,22)
    Bg.Position = UDim2.new(0,8,0,6)
    Bg.BackgroundColor3 = _G[ToggleKey] and C.MainGreen or C.ToggleOffBg
    Instance.new("UICorner", Bg).CornerRadius = UDim.new(1,0)

    local Knob = Instance.new("Frame", Bg)
    Knob.Size = UDim2.new(0,18,0,18)
    Knob.Position = _G[ToggleKey] and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)
    Knob.BackgroundColor3 = C.ToggleOffKnob
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1,0)

    local Lab = Instance.new("TextLabel", Con)
    Lab.Size = UDim2.new(1,-60,0,20)
    Lab.Position = UDim2.new(0,55,0,7)
    Lab.BackgroundTransparency = 1
    Lab.Text = Name
    Lab.Font = Enum.Font.GothamMedium
    Lab.TextColor3 = Color3.new(0.9,0.9,0.9)
    Lab.TextSize = 17
    Lab.TextXAlignment = Enum.TextXAlignment.Left

    local ValLab = Instance.new("TextLabel", Con)
    ValLab.Size = UDim2.new(0,45,0,20)
    ValLab.Position = UDim2.new(1,-55,0,7)
    ValLab.BackgroundTransparency = 1
    ValLab.Text = Def.."px"
    ValLab.Font = Enum.Font.GothamBold
    ValLab.TextColor3 = C.MainGreen
    ValLab.TextSize = 15
    ValLab.TextXAlignment = Enum.TextXAlignment.Right

    local Track = Instance.new("Frame", Con)
    Track.Size = UDim2.new(1,-25,0,5)
    Track.Position = UDim2.new(0,12,0,35)
    Track.BackgroundColor3 = Color3.fromHex("#333333")
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1,0)

    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Def-Min)/(Max-Min),0,1,0)
    Fill.BackgroundColor3 = C.MainGreen
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1,0)

    local SliderKnob = Instance.new("Frame", Track)
    SliderKnob.Size = UDim2.new(0,12,0,12)
    SliderKnob.Position = UDim2.new((Def-Min)/(Max-Min),-6,0.5,-6)
    SliderKnob.BackgroundColor3 = C.MainGreen
    Instance.new("UICorner", SliderKnob).CornerRadius = UDim.new(1,0)

    _G[ValKey] = Def
    local Drag = false

    Bg.InputBegan:Connect(function(I)
        if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then
            _G[ToggleKey] = not _G[ToggleKey]
            PlaySound(Sounds.Click)
            TweenService:Create(Bg, Anim.Fast, {BackgroundColor3 = _G[ToggleKey] and C.MainGreen or C.ToggleOffBg}):Play()
            TweenService:Create(Knob, Anim.Fast, {Position = _G[ToggleKey] and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}):Play()
            FOVCircle.Visible = _G[ToggleKey]
        end
    end)

    Track.InputBegan:Connect(function(I)
        if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then Drag = true end
    end)
    UserInputService.InputChanged:Connect(function(I)
        if Drag and (I.UserInputType == Enum.UserInputType.MouseMovement or I.UserInputType == Enum.UserInputType.Touch) then
            local Pos = I.Position
            local RelX = Pos.X - Track.AbsolutePosition.X
            local Ratio = Math.clamp(RelX / Track.AbsoluteSize.X, 0, 1)
            _G[ValKey] = Math.floor(Min + (Max - Min) * Ratio)
            ValLab.Text = _G[ValKey].."px"
            Fill.Size = UDim2.new(Ratio, 0, 1, 0)
            SliderKnob.Position = UDim2.new(Ratio, -6, 0.5, -6)
            FOVCircle.Radius = _G[ValKey]
        end
    end)
    UserInputService.InputEnded:Connect(function() Drag = false end)
end

